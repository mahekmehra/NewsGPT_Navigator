# NewsGPT Navigator — Environment Variables
# Copy this file to .env and fill in your API keys

# Groq API (free at groq.com)
GROQ_API_KEY= #INPUT YOUR API KEY

# NewsAPI (free at newsapi.org)
NEWS_API_KEY= #INPUT YOUR API KEY

# Optional overrides
BIAS_THRESHOLD=0.3
MAX_RETRIES=3
DEFAULT_LANGUAGE=en
DEFAULT_PERSONA=General
