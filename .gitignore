# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
*.whl
*.pyc
*.pyo

# ── Virtual Environment ──
venv/
.venv/
env/
ENV/

# ── Environment Variables ──
.env
.env.local
.env.production

# ── IDE / Editor ──
.vscode/
.idea/
*.swp
*.swo
*~

# ── Node / Frontend ──
node_modules/
web/node_modules/
web/dist/
web/.vite/

# ── Data (generated at runtime) ──
data/knowledge_store/*.json
!data/knowledge_store/.gitkeep
data/history.json

# ── Audio / Video (generated at runtime) ──
data/audio_output/*.mp3
!data/audio_output/.gitkeep
data/video_output/*.mp4
!data/video_output/.gitkeep
*.mp4
*.mp3
*.wav
output/

# ── FAISS indexes (generated at runtime) ──
*.faiss
*.pkl
*.index
faiss_store/

# ── Test / Coverage ──
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# ── OS ──
.DS_Store
Thumbs.db

# ── Misc ──
*.bak
*.orig
*.tmp
*.log
tmp/
temp/
